# NextTrack Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key

# Last.fm API Credentials
# Get these from https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_API_SECRET=your_lastfm_api_secret

# Dataset Configuration
# Path to the Kaggle Spotify dataset CSV
# Download from: https://www.kaggle.com/datasets/yamaerenay/spotify-dataset-19212020-600k-tracks
DATASET_PATH=data/processed/tracks.csv

# Database Configuration
DATABASE_URL=postgresql://localhost/nexttrack_dev
TEST_DATABASE_URL=postgresql://localhost/nexttrack_test

# Redis Configuration (for production caching)
REDIS_URL=redis://localhost:6379/0

# Server Configuration
PORT=5000
